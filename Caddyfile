{
  # Global options
  auto_https off
}

:80 {
  # Backend API
  handle /api/* {
    uri strip_prefix /api
    reverse_proxy backend:8080
  }

  # OpenAPI spec
  handle /openapi.yaml {
    reverse_proxy backend:8080
  }

  # Frontend - all other requests
  handle {
    reverse_proxy frontend:3000
  }

}
